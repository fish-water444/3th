  32:Core/Src/bsp_dwt.c **** 
  33:Core/Src/bsp_dwt.c ****     CPU_FREQ_Hz = CPU_Freq_mHz * 1000000;
  34:Core/Src/bsp_dwt.c ****     CPU_FREQ_Hz_ms = CPU_FREQ_Hz / 1000;
  35:Core/Src/bsp_dwt.c ****     CPU_FREQ_Hz_us = CPU_FREQ_Hz / 1000000;
  36:Core/Src/bsp_dwt.c ****     CYCCNT_RountCount = 0;
  37:Core/Src/bsp_dwt.c **** }
  38:Core/Src/bsp_dwt.c **** 
  39:Core/Src/bsp_dwt.c **** float DWT_GetDeltaT(uint32_t *cnt_last)
  40:Core/Src/bsp_dwt.c **** {
  41:Core/Src/bsp_dwt.c ****     volatile uint32_t cnt_now = DWT->CYCCNT;
  42:Core/Src/bsp_dwt.c ****     float dt = ((uint32_t)(cnt_now - *cnt_last)) / ((float)(CPU_FREQ_Hz));
  43:Core/Src/bsp_dwt.c ****     *cnt_last = cnt_now;
  44:Core/Src/bsp_dwt.c **** 
  45:Core/Src/bsp_dwt.c ****     DWT_CNT_Update();
  46:Core/Src/bsp_dwt.c **** 
  47:Core/Src/bsp_dwt.c ****     return dt;
  48:Core/Src/bsp_dwt.c **** }
  49:Core/Src/bsp_dwt.c **** 
  50:Core/Src/bsp_dwt.c **** double DWT_GetDeltaT64(uint32_t *cnt_last)
  51:Core/Src/bsp_dwt.c **** {
  52:Core/Src/bsp_dwt.c ****     volatile uint32_t cnt_now = DWT->CYCCNT;
  53:Core/Src/bsp_dwt.c ****     double dt = ((uint32_t)(cnt_now - *cnt_last)) / ((double)(CPU_FREQ_Hz));
  54:Core/Src/bsp_dwt.c ****     *cnt_last = cnt_now;
  55:Core/Src/bsp_dwt.c **** 
  56:Core/Src/bsp_dwt.c ****     DWT_CNT_Update();
  57:Core/Src/bsp_dwt.c **** 
  58:Core/Src/bsp_dwt.c ****     return dt;
  59:Core/Src/bsp_dwt.c **** }
  60:Core/Src/bsp_dwt.c **** 
  61:Core/Src/bsp_dwt.c **** void DWT_SysTimeUpdate(void)
  62:Core/Src/bsp_dwt.c **** {
  63:Core/Src/bsp_dwt.c ****     volatile uint32_t cnt_now = DWT->CYCCNT;
  64:Core/Src/bsp_dwt.c ****     static uint64_t CNT_TEMP1, CNT_TEMP2, CNT_TEMP3;
  65:Core/Src/bsp_dwt.c **** 
  66:Core/Src/bsp_dwt.c ****     DWT_CNT_Update();
  67:Core/Src/bsp_dwt.c **** 
  68:Core/Src/bsp_dwt.c ****     CYCCNT64 = (uint64_t)CYCCNT_RountCount * (uint64_t)UINT32_MAX + (uint64_t)cnt_now;
  69:Core/Src/bsp_dwt.c ****     CNT_TEMP1 = CYCCNT64 / CPU_FREQ_Hz;
  70:Core/Src/bsp_dwt.c ****     CNT_TEMP2 = CYCCNT64 - CNT_TEMP1 * CPU_FREQ_Hz;
  71:Core/Src/bsp_dwt.c ****     SysTime.s = CNT_TEMP1;
  72:Core/Src/bsp_dwt.c ****     SysTime.ms = CNT_TEMP2 / CPU_FREQ_Hz_ms;
  73:Core/Src/bsp_dwt.c ****     CNT_TEMP3 = CNT_TEMP2 - SysTime.ms * CPU_FREQ_Hz_ms;
  74:Core/Src/bsp_dwt.c ****     SysTime.us = CNT_TEMP3 / CPU_FREQ_Hz_us;
  75:Core/Src/bsp_dwt.c **** }
  76:Core/Src/bsp_dwt.c **** 
  77:Core/Src/bsp_dwt.c **** float DWT_GetTimeline_s(void)
  78:Core/Src/bsp_dwt.c **** {
  79:Core/Src/bsp_dwt.c ****     DWT_SysTimeUpdate();
  80:Core/Src/bsp_dwt.c **** 
  81:Core/Src/bsp_dwt.c ****     float DWT_Timelinef32 = SysTime.s + SysTime.ms * 0.001f + SysTime.us * 0.000001f;
  82:Core/Src/bsp_dwt.c **** 
  83:Core/Src/bsp_dwt.c ****     return DWT_Timelinef32;
  84:Core/Src/bsp_dwt.c **** }
  85:Core/Src/bsp_dwt.c **** 
  86:Core/Src/bsp_dwt.c **** float DWT_GetTimeline_ms(void)
  87:Core/Src/bsp_dwt.c **** {
  88:Core/Src/bsp_dwt.c ****     DWT_SysTimeUpdate();
ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccBue5Hi.s 			page 3


  89:Core/Src/bsp_dwt.c **** 
  90:Core/Src/bsp_dwt.c ****     float DWT_Timelinef32 = SysTime.s * 1000 + SysTime.ms + SysTime.us * 0.001f;
  91:Core/Src/bsp_dwt.c **** 
  92:Core/Src/bsp_dwt.c ****     return DWT_Timelinef32;
  93:Core/Src/bsp_dwt.c **** }
  94:Core/Src/bsp_dwt.c **** 
  95:Core/Src/bsp_dwt.c **** uint32_t DWT_GetTimeline_ms_int32(void)
  96:Core/Src/bsp_dwt.c **** {
  97:Core/Src/bsp_dwt.c ****     DWT_SysTimeUpdate();
  98:Core/Src/bsp_dwt.c ****     uint32_t DWT_Timelinef32;
  99:Core/Src/bsp_dwt.c ****     if (SysTime.us >= 500)
 100:Core/Src/bsp_dwt.c ****         DWT_Timelinef32 = SysTime.s * 1000 + SysTime.ms + 1;
 101:Core/Src/bsp_dwt.c ****     else
 102:Core/Src/bsp_dwt.c ****         DWT_Timelinef32 = SysTime.s * 1000 + SysTime.ms;
 103:Core/Src/bsp_dwt.c **** 
 104:Core/Src/bsp_dwt.c ****     return DWT_Timelinef32;
 105:Core/Src/bsp_dwt.c **** }
 106:Core/Src/bsp_dwt.c **** 
 107:Core/Src/bsp_dwt.c **** uint64_t DWT_GetTimeline_us(void)
