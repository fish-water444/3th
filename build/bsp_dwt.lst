  22:Core/Src/bsp_dwt.c **** void DWT_Init(uint32_t CPU_Freq_mHz)
  23:Core/Src/bsp_dwt.c **** {
  24:Core/Src/bsp_dwt.c ****     /* 使能DWT外设 */
  25:Core/Src/bsp_dwt.c ****     CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;
  26:Core/Src/bsp_dwt.c **** 
  27:Core/Src/bsp_dwt.c ****     /* DWT CYCCNT寄存器计数清0 */
  28:Core/Src/bsp_dwt.c ****     DWT->CYCCNT = (uint32_t)0u;
  29:Core/Src/bsp_dwt.c **** 
  30:Core/Src/bsp_dwt.c ****     /* 使能Cortex-M DWT CYCCNT寄存器 */
  31:Core/Src/bsp_dwt.c ****     DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk;
