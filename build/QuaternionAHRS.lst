 264:Application/INSTask/QuaternionAHRS.c **** void InsertQuaternionFrame(QuaternionBuf_t *qBuf, float *q, float time_stamp)
 265:Application/INSTask/QuaternionAHRS.c **** {
 266:Application/INSTask/QuaternionAHRS.c ****     if (qBuf->LatestNum == Q_FRAME_LEN - 1)
 267:Application/INSTask/QuaternionAHRS.c ****         qBuf->LatestNum = 0;
 268:Application/INSTask/QuaternionAHRS.c ****     else
 269:Application/INSTask/QuaternionAHRS.c ****         qBuf->LatestNum++;
 270:Application/INSTask/QuaternionAHRS.c **** 
 271:Application/INSTask/QuaternionAHRS.c ****     qBuf->qFrame[qBuf->LatestNum].TimeStamp = time_stamp;
 272:Application/INSTask/QuaternionAHRS.c ****     for (uint16_t i = 0; i < 4; i++)
 273:Application/INSTask/QuaternionAHRS.c ****         qBuf->qFrame[qBuf->LatestNum].q[i] = q[i];
 274:Application/INSTask/QuaternionAHRS.c **** }
 275:Application/INSTask/QuaternionAHRS.c **** 
 276:Application/INSTask/QuaternionAHRS.c **** uint16_t FindTimeMatchFrame(QuaternionBuf_t *qBuf, float match_time_stamp)
 277:Application/INSTask/QuaternionAHRS.c **** {
 278:Application/INSTask/QuaternionAHRS.c ****     float min_time_error = fabsf(qBuf->qFrame[0].TimeStamp - match_time_stamp);
 279:Application/INSTask/QuaternionAHRS.c ****     uint16_t num = 0;
 280:Application/INSTask/QuaternionAHRS.c ****     for (uint16_t i = 0; i < Q_FRAME_LEN; i++)
 281:Application/INSTask/QuaternionAHRS.c ****     {
 282:Application/INSTask/QuaternionAHRS.c ****         if (fabsf(qBuf->qFrame[i].TimeStamp - match_time_stamp) < min_time_error)
 283:Application/INSTask/QuaternionAHRS.c ****         {
 284:Application/INSTask/QuaternionAHRS.c ****             min_time_error = fabsf(qBuf->qFrame[i].TimeStamp - match_time_stamp);
 285:Application/INSTask/QuaternionAHRS.c ****             num = i;
 286:Application/INSTask/QuaternionAHRS.c ****         }
 287:Application/INSTask/QuaternionAHRS.c ****     }
 288:Application/INSTask/QuaternionAHRS.c ****     return num;
 289:Application/INSTask/QuaternionAHRS.c **** }
