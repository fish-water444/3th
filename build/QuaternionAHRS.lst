  27:Application/INSTask/QuaternionAHRS.c **** /**
  28:Application/INSTask/QuaternionAHRS.c ****   * @brief          AHRS algorithm update
  29:Application/INSTask/QuaternionAHRS.c ****   * @param[1-3]     gyro measurement in rad/s
  30:Application/INSTask/QuaternionAHRS.c ****   * @param[4-6]     accelerometer measurement in m/s2
ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccT8ohGF.s 			page 2


  31:Application/INSTask/QuaternionAHRS.c ****   * @param[7-9]     magnetometer measurement in uT
  32:Application/INSTask/QuaternionAHRS.c ****   * @param[10]      time stamp in s
  33:Application/INSTask/QuaternionAHRS.c ****   */
  34:Application/INSTask/QuaternionAHRS.c **** void Quaternion_AHRS_Update(float gx, float gy, float gz, float ax, float ay, float az, float mx, f
  35:Application/INSTask/QuaternionAHRS.c **** {
  36:Application/INSTask/QuaternionAHRS.c ****     static float recipNorm;
  37:Application/INSTask/QuaternionAHRS.c ****     static float q0q0, q0q1, q0q2, q0q3, q1q1, q1q2, q1q3, q2q2, q2q3, q3q3;
  38:Application/INSTask/QuaternionAHRS.c ****     static float hx, hy, bx, bz;
  39:Application/INSTask/QuaternionAHRS.c ****     static float halfvx, halfvy, halfvz, halfwx, halfwy, halfwz;
  40:Application/INSTask/QuaternionAHRS.c ****     static float halfex, halfey, halfez;
  41:Application/INSTask/QuaternionAHRS.c ****     static float qa, qb, qc;
  42:Application/INSTask/QuaternionAHRS.c ****     // static float dt, last_time_stamp;
  43:Application/INSTask/QuaternionAHRS.c ****     // dt = (float)(time_stamp - last_time_stamp);
  44:Application/INSTask/QuaternionAHRS.c ****     // last_time_stamp = time_stamp;
  45:Application/INSTask/QuaternionAHRS.c **** 
  46:Application/INSTask/QuaternionAHRS.c ****     // Use IMU algorithm if magnetometer measurement invalid (avoids NaN in magnetometer normalisat
  47:Application/INSTask/QuaternionAHRS.c ****     if ((mx == 0.0f) && (my == 0.0f) && (mz == 0.0f))
  48:Application/INSTask/QuaternionAHRS.c ****     {
  49:Application/INSTask/QuaternionAHRS.c ****         Quaternion_AHRS_UpdateIMU(gx, gy, gz, ax, ay, az, dt);
  50:Application/INSTask/QuaternionAHRS.c ****         return;
  51:Application/INSTask/QuaternionAHRS.c ****     }
  52:Application/INSTask/QuaternionAHRS.c **** 
  53:Application/INSTask/QuaternionAHRS.c ****     // Compute feedback only if accelerometer measurement valid (avoids NaN in accelerometer normal
  54:Application/INSTask/QuaternionAHRS.c ****     if (!((ax == 0.0f) && (ay == 0.0f) && (az == 0.0f)))
  55:Application/INSTask/QuaternionAHRS.c ****     {
  56:Application/INSTask/QuaternionAHRS.c **** 
  57:Application/INSTask/QuaternionAHRS.c ****         // Normalise accelerometer measurement
  58:Application/INSTask/QuaternionAHRS.c ****         recipNorm = invSqrt(ax * ax + ay * ay + az * az);
  59:Application/INSTask/QuaternionAHRS.c ****         ax *= recipNorm;
  60:Application/INSTask/QuaternionAHRS.c ****         ay *= recipNorm;
  61:Application/INSTask/QuaternionAHRS.c ****         az *= recipNorm;
  62:Application/INSTask/QuaternionAHRS.c **** 
  63:Application/INSTask/QuaternionAHRS.c ****         // Normalise magnetometer measurement
  64:Application/INSTask/QuaternionAHRS.c ****         recipNorm = invSqrt(mx * mx + my * my + mz * mz);
  65:Application/INSTask/QuaternionAHRS.c ****         mx *= recipNorm;
  66:Application/INSTask/QuaternionAHRS.c ****         my *= recipNorm;
  67:Application/INSTask/QuaternionAHRS.c ****         mz *= recipNorm;
  68:Application/INSTask/QuaternionAHRS.c **** 
  69:Application/INSTask/QuaternionAHRS.c ****         // Auxiliary variables to avoid repeated arithmetic
  70:Application/INSTask/QuaternionAHRS.c ****         q0q0 = q0 * q0;
  71:Application/INSTask/QuaternionAHRS.c ****         q0q1 = q0 * q1;
  72:Application/INSTask/QuaternionAHRS.c ****         q0q2 = q0 * q2;
  73:Application/INSTask/QuaternionAHRS.c ****         q0q3 = q0 * q3;
  74:Application/INSTask/QuaternionAHRS.c ****         q1q1 = q1 * q1;
  75:Application/INSTask/QuaternionAHRS.c ****         q1q2 = q1 * q2;
  76:Application/INSTask/QuaternionAHRS.c ****         q1q3 = q1 * q3;
  77:Application/INSTask/QuaternionAHRS.c ****         q2q2 = q2 * q2;
  78:Application/INSTask/QuaternionAHRS.c ****         q2q3 = q2 * q3;
  79:Application/INSTask/QuaternionAHRS.c ****         q3q3 = q3 * q3;
  80:Application/INSTask/QuaternionAHRS.c **** 
  81:Application/INSTask/QuaternionAHRS.c ****         // Reference direction of Earth's magnetic field
  82:Application/INSTask/QuaternionAHRS.c ****         hx = 2.0f * (mx * (0.5f - q2q2 - q3q3) + my * (q1q2 - q0q3) + mz * (q1q3 + q0q2));
  83:Application/INSTask/QuaternionAHRS.c ****         hy = 2.0f * (mx * (q1q2 + q0q3) + my * (0.5f - q1q1 - q3q3) + mz * (q2q3 - q0q1));
  84:Application/INSTask/QuaternionAHRS.c ****         bx = sqrt(hx * hx + hy * hy);
  85:Application/INSTask/QuaternionAHRS.c ****         bz = 2.0f * (mx * (q1q3 - q0q2) + my * (q2q3 + q0q1) + mz * (0.5f - q1q1 - q2q2));
  86:Application/INSTask/QuaternionAHRS.c **** 
  87:Application/INSTask/QuaternionAHRS.c ****         // Estimated direction of gravity and magnetic field
ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccT8ohGF.s 			page 3


  88:Application/INSTask/QuaternionAHRS.c ****         halfvx = q1q3 - q0q2;
  89:Application/INSTask/QuaternionAHRS.c ****         halfvy = q0q1 + q2q3;
  90:Application/INSTask/QuaternionAHRS.c ****         halfvz = q0q0 - 0.5f + q3q3;
  91:Application/INSTask/QuaternionAHRS.c ****         halfwx = bx * (0.5f - q2q2 - q3q3) + bz * (q1q3 - q0q2);
  92:Application/INSTask/QuaternionAHRS.c ****         halfwy = bx * (q1q2 - q0q3) + bz * (q0q1 + q2q3);
  93:Application/INSTask/QuaternionAHRS.c ****         halfwz = bx * (q0q2 + q1q3) + bz * (0.5f - q1q1 - q2q2);
  94:Application/INSTask/QuaternionAHRS.c **** 
  95:Application/INSTask/QuaternionAHRS.c ****         // Error is sum of cross product between estimated direction and measured direction of fiel
  96:Application/INSTask/QuaternionAHRS.c ****         halfex = (ay * halfvz - az * halfvy) + (my * halfwz - mz * halfwy);
  97:Application/INSTask/QuaternionAHRS.c ****         halfey = (az * halfvx - ax * halfvz) + (mz * halfwx - mx * halfwz);
  98:Application/INSTask/QuaternionAHRS.c ****         halfez = (ax * halfvy - ay * halfvx) + (mx * halfwy - my * halfwx);
  99:Application/INSTask/QuaternionAHRS.c **** 
 100:Application/INSTask/QuaternionAHRS.c ****         // Compute and apply integral feedback if enabled
 101:Application/INSTask/QuaternionAHRS.c ****         if (twoKi > 0.0f)
 102:Application/INSTask/QuaternionAHRS.c ****         {
 103:Application/INSTask/QuaternionAHRS.c ****             integralFBx += twoKi * halfex * dt; // integral error scaled by Ki
 104:Application/INSTask/QuaternionAHRS.c ****             integralFBy += twoKi * halfey * dt;
 105:Application/INSTask/QuaternionAHRS.c ****             integralFBz += twoKi * halfez * dt;
 106:Application/INSTask/QuaternionAHRS.c ****             gx += integralFBx; // apply integral feedback
 107:Application/INSTask/QuaternionAHRS.c ****             gy += integralFBy;
 108:Application/INSTask/QuaternionAHRS.c ****             gz += integralFBz;
 109:Application/INSTask/QuaternionAHRS.c ****         }
 110:Application/INSTask/QuaternionAHRS.c ****         else
 111:Application/INSTask/QuaternionAHRS.c ****         {
 112:Application/INSTask/QuaternionAHRS.c ****             integralFBx = 0.0f; // prevent integral windup
 113:Application/INSTask/QuaternionAHRS.c ****             integralFBy = 0.0f;
 114:Application/INSTask/QuaternionAHRS.c ****             integralFBz = 0.0f;
 115:Application/INSTask/QuaternionAHRS.c ****         }
 116:Application/INSTask/QuaternionAHRS.c **** 
 117:Application/INSTask/QuaternionAHRS.c ****         // Apply proportional feedback
 118:Application/INSTask/QuaternionAHRS.c ****         gx += twoKp * halfex;
 119:Application/INSTask/QuaternionAHRS.c ****         gy += twoKp * halfey;
 120:Application/INSTask/QuaternionAHRS.c ****         gz += twoKp * halfez;
 121:Application/INSTask/QuaternionAHRS.c ****     }
 122:Application/INSTask/QuaternionAHRS.c **** 
 123:Application/INSTask/QuaternionAHRS.c ****     // Integrate rate of change of quaternion
 124:Application/INSTask/QuaternionAHRS.c ****     gx *= (0.5f * dt); // pre-multiply common factors
 125:Application/INSTask/QuaternionAHRS.c ****     gy *= (0.5f * dt);
 126:Application/INSTask/QuaternionAHRS.c ****     gz *= (0.5f * dt);
 127:Application/INSTask/QuaternionAHRS.c ****     qa = q0;
 128:Application/INSTask/QuaternionAHRS.c ****     qb = q1;
 129:Application/INSTask/QuaternionAHRS.c ****     qc = q2;
 130:Application/INSTask/QuaternionAHRS.c ****     q0 += (-qb * gx - qc * gy - q3 * gz);
 131:Application/INSTask/QuaternionAHRS.c ****     q1 += (qa * gx + qc * gz - q3 * gy);
 132:Application/INSTask/QuaternionAHRS.c ****     q2 += (qa * gy - qb * gz + q3 * gx);
 133:Application/INSTask/QuaternionAHRS.c ****     q3 += (qa * gz + qb * gy - qc * gx);
 134:Application/INSTask/QuaternionAHRS.c **** 
 135:Application/INSTask/QuaternionAHRS.c ****     // Normalise quaternion
 136:Application/INSTask/QuaternionAHRS.c ****     recipNorm = invSqrt(q0 * q0 + q1 * q1 + q2 * q2 + q3 * q3);
 137:Application/INSTask/QuaternionAHRS.c ****     q0 *= recipNorm;
 138:Application/INSTask/QuaternionAHRS.c ****     q1 *= recipNorm;
 139:Application/INSTask/QuaternionAHRS.c ****     q2 *= recipNorm;
 140:Application/INSTask/QuaternionAHRS.c ****     q3 *= recipNorm;
 141:Application/INSTask/QuaternionAHRS.c **** 
 142:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[0] = q0;
 143:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[1] = q1;
 144:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[2] = q2;
ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccT8ohGF.s 			page 4


 145:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[3] = q3;
 146:Application/INSTask/QuaternionAHRS.c **** }
 147:Application/INSTask/QuaternionAHRS.c **** 
 148:Application/INSTask/QuaternionAHRS.c **** /**
 149:Application/INSTask/QuaternionAHRS.c ****   * @brief          IMU algorithm update
 150:Application/INSTask/QuaternionAHRS.c ****   * @param[1-3]     gyro measurement in rad/s
 151:Application/INSTask/QuaternionAHRS.c ****   * @param[4-6]     accelerometer measurement in m/s2
 152:Application/INSTask/QuaternionAHRS.c ****   * @param[7]      time stamp in s
 153:Application/INSTask/QuaternionAHRS.c ****   */
 154:Application/INSTask/QuaternionAHRS.c **** void Quaternion_AHRS_UpdateIMU(float gx, float gy, float gz, float ax, float ay, float az, float dt
 155:Application/INSTask/QuaternionAHRS.c **** {
 156:Application/INSTask/QuaternionAHRS.c ****     static float recipNorm;
 157:Application/INSTask/QuaternionAHRS.c ****     static float halfvx, halfvy, halfvz;
 158:Application/INSTask/QuaternionAHRS.c ****     static float halfex, halfey, halfez;
 159:Application/INSTask/QuaternionAHRS.c ****     static float qa, qb, qc;
 160:Application/INSTask/QuaternionAHRS.c ****     // static float dt, last_time_stamp;
 161:Application/INSTask/QuaternionAHRS.c ****     // dt = (float)(time_stamp - last_time_stamp);
 162:Application/INSTask/QuaternionAHRS.c ****     // last_time_stamp = time_stamp;
 163:Application/INSTask/QuaternionAHRS.c **** 
 164:Application/INSTask/QuaternionAHRS.c ****     // Compute feedback only if accelerometer measurement valid (avoids NaN in accelerometer normal
 165:Application/INSTask/QuaternionAHRS.c ****     if (!((ax == 0.0f) && (ay == 0.0f) && (az == 0.0f)))
 166:Application/INSTask/QuaternionAHRS.c ****     {
 167:Application/INSTask/QuaternionAHRS.c **** 
 168:Application/INSTask/QuaternionAHRS.c ****         // Normalise accelerometer measurement
 169:Application/INSTask/QuaternionAHRS.c ****         recipNorm = invSqrt(ax * ax + ay * ay + az * az);
 170:Application/INSTask/QuaternionAHRS.c ****         ax *= recipNorm;
 171:Application/INSTask/QuaternionAHRS.c ****         ay *= recipNorm;
 172:Application/INSTask/QuaternionAHRS.c ****         az *= recipNorm;
 173:Application/INSTask/QuaternionAHRS.c **** 
 174:Application/INSTask/QuaternionAHRS.c ****         // Estimated direction of gravity and vector perpendicular to magnetic flux
 175:Application/INSTask/QuaternionAHRS.c ****         halfvx = q1 * q3 - q0 * q2;
 176:Application/INSTask/QuaternionAHRS.c ****         halfvy = q0 * q1 + q2 * q3;
 177:Application/INSTask/QuaternionAHRS.c ****         halfvz = q0 * q0 - 0.5f + q3 * q3;
 178:Application/INSTask/QuaternionAHRS.c **** 
 179:Application/INSTask/QuaternionAHRS.c ****         // Error is sum of cross product between estimated and measured direction of gravity
 180:Application/INSTask/QuaternionAHRS.c ****         halfex = (ay * halfvz - az * halfvy);
 181:Application/INSTask/QuaternionAHRS.c ****         halfey = (az * halfvx - ax * halfvz);
 182:Application/INSTask/QuaternionAHRS.c ****         halfez = (ax * halfvy - ay * halfvx);
 183:Application/INSTask/QuaternionAHRS.c **** 
 184:Application/INSTask/QuaternionAHRS.c ****         // Compute and apply integral feedback if enabled
 185:Application/INSTask/QuaternionAHRS.c ****         if (twoKi > 0.0f)
 186:Application/INSTask/QuaternionAHRS.c ****         {
 187:Application/INSTask/QuaternionAHRS.c ****             integralFBx += twoKi * halfex * dt; // integral error scaled by Ki
 188:Application/INSTask/QuaternionAHRS.c ****             integralFBy += twoKi * halfey * dt;
 189:Application/INSTask/QuaternionAHRS.c ****             integralFBz += twoKi * halfez * dt;
 190:Application/INSTask/QuaternionAHRS.c ****             gx += integralFBx; // apply integral feedback
 191:Application/INSTask/QuaternionAHRS.c ****             gy += integralFBy;
 192:Application/INSTask/QuaternionAHRS.c ****             gz += integralFBz;
 193:Application/INSTask/QuaternionAHRS.c ****         }
 194:Application/INSTask/QuaternionAHRS.c ****         else
 195:Application/INSTask/QuaternionAHRS.c ****         {
 196:Application/INSTask/QuaternionAHRS.c ****             integralFBx = 0.0f; // prevent integral windup
 197:Application/INSTask/QuaternionAHRS.c ****             integralFBy = 0.0f;
 198:Application/INSTask/QuaternionAHRS.c ****             integralFBz = 0.0f;
 199:Application/INSTask/QuaternionAHRS.c ****         }
 200:Application/INSTask/QuaternionAHRS.c **** 
 201:Application/INSTask/QuaternionAHRS.c ****         // Apply proportional feedback
ARM GAS  C:\Users\LENOVO\AppData\Local\Temp\ccT8ohGF.s 			page 5


 202:Application/INSTask/QuaternionAHRS.c ****         gx += twoKp * halfex;
 203:Application/INSTask/QuaternionAHRS.c ****         gy += twoKp * halfey;
 204:Application/INSTask/QuaternionAHRS.c ****         gz += twoKp * halfez;
 205:Application/INSTask/QuaternionAHRS.c ****     }
 206:Application/INSTask/QuaternionAHRS.c **** 
 207:Application/INSTask/QuaternionAHRS.c ****     // Integrate rate of change of quaternion
 208:Application/INSTask/QuaternionAHRS.c ****     gx *= (0.5f * dt); // pre-multiply common factors
 209:Application/INSTask/QuaternionAHRS.c ****     gy *= (0.5f * dt);
 210:Application/INSTask/QuaternionAHRS.c ****     gz *= (0.5f * dt);
 211:Application/INSTask/QuaternionAHRS.c ****     qa = q0;
 212:Application/INSTask/QuaternionAHRS.c ****     qb = q1;
 213:Application/INSTask/QuaternionAHRS.c ****     qc = q2;
 214:Application/INSTask/QuaternionAHRS.c ****     q0 += (-qb * gx - qc * gy - q3 * gz);
 215:Application/INSTask/QuaternionAHRS.c ****     q1 += (qa * gx + qc * gz - q3 * gy);
 216:Application/INSTask/QuaternionAHRS.c ****     q2 += (qa * gy - qb * gz + q3 * gx);
 217:Application/INSTask/QuaternionAHRS.c ****     q3 += (qa * gz + qb * gy - qc * gx);
 218:Application/INSTask/QuaternionAHRS.c **** 
 219:Application/INSTask/QuaternionAHRS.c ****     // Normalise quaternion
 220:Application/INSTask/QuaternionAHRS.c ****     recipNorm = invSqrt(q0 * q0 + q1 * q1 + q2 * q2 + q3 * q3);
 221:Application/INSTask/QuaternionAHRS.c ****     q0 *= recipNorm;
 222:Application/INSTask/QuaternionAHRS.c ****     q1 *= recipNorm;
 223:Application/INSTask/QuaternionAHRS.c ****     q2 *= recipNorm;
 224:Application/INSTask/QuaternionAHRS.c ****     q3 *= recipNorm;
 225:Application/INSTask/QuaternionAHRS.c **** 
 226:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[0] = q0;
 227:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[1] = q1;
 228:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[2] = q2;
 229:Application/INSTask/QuaternionAHRS.c ****     AHRS.q[3] = q3;
 230:Application/INSTask/QuaternionAHRS.c **** }
 231:Application/INSTask/QuaternionAHRS.c **** 
 232:Application/INSTask/QuaternionAHRS.c **** /**
 233:Application/INSTask/QuaternionAHRS.c ****   * @brief        Convert quaternion to eular angle
 234:Application/INSTask/QuaternionAHRS.c ****   */
 235:Application/INSTask/QuaternionAHRS.c **** void Get_EulerAngle(float *q)
 236:Application/INSTask/QuaternionAHRS.c **** {
 237:Application/INSTask/QuaternionAHRS.c ****     static int16_t Pitch_Round_Count = 0;
 238:Application/INSTask/QuaternionAHRS.c ****     static int16_t Yaw_Round_Count = 0;
 239:Application/INSTask/QuaternionAHRS.c ****     static float Pitch_Angle_Last = 0;
 240:Application/INSTask/QuaternionAHRS.c ****     static float Yaw_Angle_Last = 0;
 241:Application/INSTask/QuaternionAHRS.c **** 
 242:Application/INSTask/QuaternionAHRS.c ****     AHRS.Yaw = atan2f(2.0f * (q[0] * q[3] + q[1] * q[2]), 2.0f * (q[0] * q[0] + q[1] * q[1]) - 1.0f
 243:Application/INSTask/QuaternionAHRS.c ****     AHRS.Pitch = atan2f(2.0f * (q[0] * q[1] + q[2] * q[3]), 2.0f * (q[0] * q[0] + q[3] * q[3]) - 1.
 244:Application/INSTask/QuaternionAHRS.c ****     AHRS.Roll = asinf(-2.0f * (q[1] * q[3] - q[0] * q[2])) * 57.295779513f;
 245:Application/INSTask/QuaternionAHRS.c **** 
 246:Application/INSTask/QuaternionAHRS.c ****     // Yaw rount count
 247:Application/INSTask/QuaternionAHRS.c ****     if (AHRS.Yaw - Yaw_Angle_Last > 180.0f)
 248:Application/INSTask/QuaternionAHRS.c ****         Yaw_Round_Count--;
 249:Application/INSTask/QuaternionAHRS.c ****     else if (AHRS.Yaw - Yaw_Angle_Last < -180.0f)
 250:Application/INSTask/QuaternionAHRS.c ****         Yaw_Round_Count++;
 251:Application/INSTask/QuaternionAHRS.c ****     // Pitch rount count
 252:Application/INSTask/QuaternionAHRS.c ****     if (AHRS.Pitch - Pitch_Angle_Last > 180.0f)
 253:Application/INSTask/QuaternionAHRS.c ****         Pitch_Round_Count--;
 254:Application/INSTask/QuaternionAHRS.c ****     else if (AHRS.Pitch - Pitch_Angle_Last < -180.0f)
 255:Application/INSTask/QuaternionAHRS.c ****         Pitch_Round_Count++;
 256:Application/INSTask/QuaternionAHRS.c **** 
 257:Application/INSTask/QuaternionAHRS.c ****     AHRS.YawTotalAngle = 360.0f * Yaw_Round_Count + AHRS.Yaw;
 258:Application/INSTask/QuaternionAHRS.c ****     AHRS.PitchTotalAngle = 360.0f * Pitch_Round_Count + AHRS.Pitch;
