 291:Application/INSTask/QuaternionAHRS.c **** /**
 292:Application/INSTask/QuaternionAHRS.c ****   * @brief          Transform 3dvector from BodyFrame to EarthFrame
 293:Application/INSTask/QuaternionAHRS.c ****   * @param[1]       vector in BodyFrame
 294:Application/INSTask/QuaternionAHRS.c ****   * @param[2]       vector in EarthFrame
 295:Application/INSTask/QuaternionAHRS.c ****   * @param[3]       quaternion
 296:Application/INSTask/QuaternionAHRS.c ****   */
 297:Application/INSTask/QuaternionAHRS.c **** void BodyFrameToEarthFrame(float *vecBF, float *vecEF, float *q)
 298:Application/INSTask/QuaternionAHRS.c **** {
 299:Application/INSTask/QuaternionAHRS.c ****     vecEF[0] = 2.0f * ((0.5f - q[2] * q[2] - q[3] * q[3]) * vecBF[0] +
 300:Application/INSTask/QuaternionAHRS.c ****                        (q[1] * q[2] - q[0] * q[3]) * vecBF[1] +
 301:Application/INSTask/QuaternionAHRS.c ****                        (q[1] * q[3] + q[0] * q[2]) * vecBF[2]);
 302:Application/INSTask/QuaternionAHRS.c **** 
 303:Application/INSTask/QuaternionAHRS.c ****     vecEF[1] = 2.0f * ((q[1] * q[2] + q[0] * q[3]) * vecBF[0] +
 304:Application/INSTask/QuaternionAHRS.c ****                        (0.5f - q[1] * q[1] - q[3] * q[3]) * vecBF[1] +
 305:Application/INSTask/QuaternionAHRS.c ****                        (q[2] * q[3] - q[0] * q[1]) * vecBF[2]);
 306:Application/INSTask/QuaternionAHRS.c **** 
 307:Application/INSTask/QuaternionAHRS.c ****     vecEF[2] = 2.0f * ((q[1] * q[3] - q[0] * q[2]) * vecBF[0] +
 308:Application/INSTask/QuaternionAHRS.c ****                        (q[2] * q[3] + q[0] * q[1]) * vecBF[1] +
 309:Application/INSTask/QuaternionAHRS.c ****                        (0.5f - q[1] * q[1] - q[2] * q[2]) * vecBF[2]);
 310:Application/INSTask/QuaternionAHRS.c **** }
