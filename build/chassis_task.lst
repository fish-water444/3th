 104:Application/ChassisTask/chassis_task.c **** static void Chassis_Set_Mode(void)
 105:Application/ChassisTask/chassis_task.c **** {
 106:Application/ChassisTask/chassis_task.c ****     // 4个底盘电机全部离线 → 强制静止
 107:Application/ChassisTask/chassis_task.c ****     if (is_TOE_Error(CHASSIS_MOTOR1_TOE) &&
 108:Application/ChassisTask/chassis_task.c ****         is_TOE_Error(CHASSIS_MOTOR2_TOE) &&
 109:Application/ChassisTask/chassis_task.c ****         is_TOE_Error(CHASSIS_MOTOR3_TOE) &&
 110:Application/ChassisTask/chassis_task.c ****         is_TOE_Error(CHASSIS_MOTOR4_TOE))
 111:Application/ChassisTask/chassis_task.c ****     {
 112:Application/ChassisTask/chassis_task.c ****         Chassis.Mode = Silence_Mode;
 113:Application/ChassisTask/chassis_task.c ****     }
 114:Application/ChassisTask/chassis_task.c ****     else
 115:Application/ChassisTask/chassis_task.c ****     {
 116:Application/ChassisTask/chassis_task.c ****         // 左拨杆切换旋转模式（右拨杆已被云台占用控制枪管）
 117:Application/ChassisTask/chassis_task.c ****         Chassis.Mode = Follow_Mode;
 118:Application/ChassisTask/chassis_task.c ****     }
 119:Application/ChassisTask/chassis_task.c **** 
 120:Application/ChassisTask/chassis_task.c ****     Chassis.LastMode = Chassis.Mode;
 121:Application/ChassisTask/chassis_task.c **** }
