 123:Application/ChassisTask/chassis_task.c **** static void Chassis_Set_Control(void)
 124:Application/ChassisTask/chassis_task.c **** {
 125:Application/ChassisTask/chassis_task.c ****     float yaw_rad; // IMU Yaw角(弧度) — 对标百零一 SpinningValidTheta
 126:Application/ChassisTask/chassis_task.c **** 
 127:Application/ChassisTask/chassis_task.c ****     switch (Chassis.Mode)
 128:Application/ChassisTask/chassis_task.c ****     {
 129:Application/ChassisTask/chassis_task.c ****     case Follow_Mode:
 130:Application/ChassisTask/chassis_task.c ****         // 左拨杆向下(Switch_Down=2)：自动旋转 + 摇杆平移
 131:Application/ChassisTask/chassis_task.c ****         if (remote_control.switch_left == Switch_Down)
 132:Application/ChassisTask/chassis_task.c ****         {
 133:Application/ChassisTask/chassis_task.c ****             Chassis.Vr = 50.0f; // 自动旋转角速度 50°/s
 134:Application/ChassisTask/chassis_task.c ****         }
 135:Application/ChassisTask/chassis_task.c ****         else
 136:Application/ChassisTask/chassis_task.c ****         {
 137:Application/ChassisTask/chassis_task.c ****             Chassis.Vr = 0; // 不自动旋转
 138:Application/ChassisTask/chassis_task.c ****         }
 139:Application/ChassisTask/chassis_task.c **** 
 140:Application/ChassisTask/chassis_task.c ****         // 使用IMU真实Yaw角(度→弧度) — 对标百零一 SpinningValidTheta
 141:Application/ChassisTask/chassis_task.c ****         yaw_rad = AHRS.Yaw * pi / 180.0f;
 142:Application/ChassisTask/chassis_task.c **** 
 143:Application/ChassisTask/chassis_task.c ****         // 对标百零一 Battle_MODE 坐标变换: sin(θ)*Vx - cos(θ)*Vy, cos(θ)*Vx + sin(θ)*
 144:Application/ChassisTask/chassis_task.c ****         Chassis.VxTransfer =  user_sin(yaw_rad) * Chassis.Vx - user_cos(yaw_rad) * Chassis.Vy;
