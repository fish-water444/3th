 145:Application/ChassisTask/chassis_task.c ****         Chassis.VyTransfer =  user_cos(yaw_rad) * Chassis.Vx + user_sin(yaw_rad) * Chassis.Vy;
 146:Application/ChassisTask/chassis_task.c ****         break;
 147:Application/ChassisTask/chassis_task.c **** 
 148:Application/ChassisTask/chassis_task.c ****     case Silence_Mode:
 149:Application/ChassisTask/chassis_task.c ****     default:
 150:Application/ChassisTask/chassis_task.c ****         Chassis.Vr = 0;
 151:Application/ChassisTask/chassis_task.c ****         Chassis.VxTransfer = 0;
